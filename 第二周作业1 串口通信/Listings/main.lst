   9          
  10          unsigned char Receive_Data;                      //最近一次收到的串口字节
  11          bit ReceiveFlag;                                 //接收完成标志位 1 接收到字节 0 处理完成
  12          
  13          unsigned char ReceiveBuffer[SAVE_DATA_MAX];      //字符串缓冲区
