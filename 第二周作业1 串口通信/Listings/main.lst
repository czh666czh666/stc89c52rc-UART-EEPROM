  67          void SaveToEEPROM(void)  //把缓冲区内容写入EEPROM，地址0：长度，地址1~n：字符串内容
  68          {
  69   1          unsigned char i;
  70   1      
  71   1          AT24C02_WriteByte(0x00,ReceiveCount);   // 先存长度
  72   1      
  73   1          for(i=0;i<ReceiveCount;i++)
  74   1          {
  75   2              AT24C02_WriteByte(i+1,ReceiveBuffer[i]);
  76   2          }
  77   1      
  78   1      }
  79          
  80          void ShowFromEEPROM(void)  //上电后从EEPROM读出并显示
  81          {
  82   1          unsigned char i;
  83   1          unsigned char len;
  84   1      
  85   1          len = AT24C02_ReadByte(0x00);  //获得长度
  86   1      
  87   1          UART_SendString("EEPROM:");
  88   1      
  89   1          if(len==0xFF || len==0 || len>SAVE_DATA_MAX)
  90   1          {
  91   2              UART_SendString("NO DATA\r\n");
  92   2              return;
  93   2          }
  94   1      
  95   1          for(i=0;i<len;i++)      //依次读取字符
  96   1          {
  97   2              UART_SendByte(AT24C02_ReadByte(i+1));
  98   2          }
  99   1      
 100   1          UART_SendString("\r\n");
 101   1      }
